@model TodoEditViewModel
@{
    ViewData["Title"] = "Redigera todo";
}

<section class="edit-shell">
    <div class="edit-card">
        <a class="back-link" asp-action="Index"><i class="bi bi-arrow-left"></i> Tillbaka</a>
        <div class="panel-heading">
            <span class="panel-icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1>Redigera todo</h1>
                <p>Uppdatera innehåll, deadline och status.</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="todo-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label asp-for="Title" class="form-label">Titel</label>
            <input asp-for="Title" class="form-control form-control-lg" />
            <span asp-validation-for="Title" class="text-danger"></span>

            <label asp-for="Description" class="form-label">Beskrivning</label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>

            <label asp-for="DueDateUtc" class="form-label">Deadline</label>
            <input asp-for="DueDateUtc" type="datetime-local" class="form-control" />

            <label class="status-toggle">
                <input asp-for="IsCompleted" />
                <span><i class="bi bi-check2-circle"></i> Markera som klar</span>
            </label>

            <button class="btn btn-primary btn-lg" type="submit"><i class="bi bi-save"></i> Spara ändringar</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
